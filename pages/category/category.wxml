<!--pages/category/category.wxml-->
<view class="container">
  <!-- 分类列表 -->
  <view class="category-list">
    <view class="category-item" 
          wx:for="{{categories}}" 
          wx:key="id">
      <view class="category-color" style="background-color: {{item.color}}"></view>
      <view class="category-name">{{item.name}}</view>
      <view class="category-actions">
        <view class="action-btn edit" 
              bindtap="onEditCategory" 
              data-id="{{item.id}}">
          编辑
        </view>
        <view class="action-btn delete" 
              bindtap="onDeleteCategory" 
              data-id="{{item.id}}">
          删除
        </view>
      </view>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-category-btn" bindtap="onAddCategory">
    <text class="add-icon">+</text>
    <text class="add-text">添加分类</text>
  </view>

  <!-- 编辑弹窗 -->
  <view class="modal-overlay" wx:if="{{showEditModal}}" bindtap="hideEditModal">
    <view class="modal-content" catchtap="true">
      <view class="modal-header">
        <text class="modal-title">{{editingId ? '编辑分类' : '新增分类'}}</text>
        <view class="modal-close" bindtap="hideEditModal">✕</view>
      </view>

      <view class="modal-body">
        <!-- 名称输入 -->
        <view class="form-item">
          <view class="form-label">分类名称</view>
          <input 
            class="form-input" 
            placeholder="输入分类名称" 
            value="{{editName}}"
            maxlength="10"
            bindinput="onNameInput"
            focus
          />
        </view>

        <!-- 颜色选择 -->
        <view class="form-item">
          <view class="form-label">分类颜色</view>
          <view class="color-grid">
            <view class="color-item {{editColor === color ? 'active' : ''}}" 
                  wx:for="{{colorOptions}}" 
                  wx:key="*this"
                  data-color="{{color}}"
                  bindtap="onColorSelect"
                  style="background-color: {{color}}">
              <view class="color-check" wx:if="{{editColor === color}}">✓</view>
            </view>
          </view>
        </view>
      </view>

      <view class="modal-footer">
        <view class="btn-cancel" bindtap="hideEditModal">取消</view>
        <view class="btn-save" bindtap="onSaveCategory">保存</view>
      </view>
    </view>
  </view>
</view>
