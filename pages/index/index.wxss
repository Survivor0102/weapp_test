/* pages/index/index.wxss */
@import '../../styles/variables.wxss';

.container {
  padding: 0;
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: 140rpx;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: var(--card-bg);
  padding: 30rpx 20rpx;
  margin: 20rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-number {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-color);
}

.stats-number.active {
  color: var(--primary-color);
}

.stats-number.completed {
  color: var(--success-color);
}

.stats-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.stats-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: var(--border-color);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background-color: var(--card-bg);
  margin: 0 20rpx 20rpx;
  padding: 20rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: var(--text-light);
  border-radius: var(--radius-sm);
  transition: all 0.3s;
}

.filter-item.active {
  background-color: var(--primary-color);
  color: #fff;
  font-weight: 500;
}

/* 分类标签 */
.category-tags {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx 20rpx;
  gap: 16rpx;
}

.category-tag {
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.category-tag.active {
  transform: scale(1.05);
}

/* 待办列表 */
.todo-list {
  padding: 0 20rpx;
}

.todo-item {
  display: flex;
  align-items: flex-start;
  background-color: var(--card-bg);
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: all 0.3s;
}

.todo-item:active {
  transform: scale(0.98);
}

/* 复选框 */
.todo-checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid var(--border-color);
  border-radius: var(--radius-full);
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s;
}

.todo-checkbox.completed {
  background-color: var(--success-color);
  border-color: var(--success-color);
}

.checkbox-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

/* 内容区域 */
.todo-content {
  flex: 1;
  min-width: 0;
}

.todo-title {
  font-size: 30rpx;
  color: var(--text-color);
  margin-bottom: 12rpx;
  word-break: break-all;
  line-height: 1.4;
}

.todo-title.completed {
  text-decoration: line-through;
  color: var(--text-light);
}

.todo-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
}

.todo-category {
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  color: #fff;
}

.todo-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.todo-priority {
  font-size: 22rpx;
  font-weight: 500;
}

/* 删除按钮 */
.todo-delete {
  padding: 12rpx 20rpx;
  margin-left: 16rpx;
  color: var(--danger-color);
  font-size: 24rpx;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-light);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-light);
  opacity: 0.7;
}

/* 添加按钮 */
.add-button {
  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: var(--primary-color);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
  transition: all 0.3s;
}

.add-button:active {
  transform: scale(0.9);
}

.add-icon {
  font-size: 60rpx;
  color: #fff;
  font-weight: 300;
}
