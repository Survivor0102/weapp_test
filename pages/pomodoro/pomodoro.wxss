/* pages/pomodoro/pomodoro.wxss */
@import '../../styles/variables.wxss';

.container {
  padding: 0;
  min-height: 100vh;
  background-color: var(--bg-color);
}

/* 模式切换 */
.mode-tabs {
  display: flex;
  background-color: var(--card-bg);
  padding: 20rpx;
  gap: 20rpx;
}

.mode-tab {
  flex: 1;
  padding: 20rpx 10rpx;
  text-align: center;
  border-radius: var(--radius-md);
  font-size: 24rpx;
  color: var(--text-light);
  background-color: var(--bg-color);
  transition: all 0.3s;
}

.mode-tab.active {
  color: #fff;
  font-weight: 500;
}

/* 计时器区域 */
.timer-section {
  padding: 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: background-color 0.5s;
}

.timer-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.timer-time {
  font-size: 120rpx;
  font-weight: bold;
  color: #fff;
  font-family: 'Courier New', monospace;
  line-height: 1;
}

.timer-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 20rpx;
}

/* 关联待办 */
.linked-todo,
.link-todo {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 20rpx 30rpx;
  border-radius: var(--radius-full);
  margin-bottom: 40rpx;
  min-width: 400rpx;
}

.todo-tag {
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 26rpx;
}

.todo-icon {
  margin-right: 10rpx;
}

.todo-title {
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unlink-btn {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
  padding: 10rpx 20rpx;
}

.link-text {
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
}

/* 控制按钮 */
.control-buttons {
  display: flex;
  gap: 30rpx;
}

.btn-reset,
.btn-toggle {
  padding: 24rpx 60rpx;
  border-radius: var(--radius-full);
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.btn-reset {
  background-color: rgba(255, 255, 255, 0.3);
  color: #fff;
}

.btn-reset:active {
  opacity: 0.7;
}

.btn-toggle {
  background-color: #fff;
  color: var(--text-color);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.btn-toggle:active {
  transform: scale(0.95);
}

/* 统计区域 */
.stats-section {
  background-color: var(--card-bg);
  padding: 40rpx 30rpx;
  margin: 30rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  text-align: center;
}

.stats-title {
  font-size: 28rpx;
  color: var(--text-light);
  margin-bottom: 20rpx;
}

.stats-tomatoes {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.tomato {
  font-size: 40rpx;
}

.tomato-empty {
  font-size: 40rpx;
  opacity: 0.2;
}

.stats-count {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 选择器 */
.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.picker-content {
  width: 100%;
  background-color: var(--card-bg);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  max-height: 60vh;
  overflow: hidden;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
}

.picker-close {
  font-size: 36rpx;
  color: var(--text-light);
  padding: 10rpx;
}

.picker-body {
  max-height: 400rpx;
  overflow-y: auto;
  padding: 20rpx;
}

.todo-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: var(--radius-sm);
  transition: all 0.3s;
}

.todo-option:active {
  background-color: var(--bg-color);
}

.todo-option-title {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-color);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.todo-option-check {
  color: var(--success-color);
  font-size: 32rpx;
  font-weight: bold;
  margin-left: 20rpx;
}

.empty-tip {
  padding: 60rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-light);
}
