<!--components/virtual-list/virtual-list.wxml-->
<view class="virtual-list" wx:if="{{enableVirtual}}">
  <scroll-view 
    class="scroll-view" 
    scroll-y 
    scroll-top="{{scrollTop}}"
    bindscroll="onScroll"
    style="height: {{totalHeight}}rpx"
  >
    <view class="virtual-spacer" style="height: {{totalHeight}}rpx; position: relative;">
      <view 
        class="virtual-item" 
        wx:for="{{visibleItems}}" 
        wx:key="id"
        data-index="{{index}}"
        style="position: absolute; top: {{offsetTop}}rpx; transform: translateY({{(index * itemHeight)}}rpx);"
      >
        <slot item="{{item}}" index="{{index}}"></slot>
      </view>
    </view>
  </scroll-view>
</view>

<!-- 普通列表（数据少时使用） -->
<view class="normal-list" wx:else>
  <view 
    class="normal-item" 
    wx:for="{{items}}" 
    wx:key="id"
    data-index="{{index}}"
  >
    <slot item="{{item}}" index="{{index}}"></slot>
  </view>
</view>
